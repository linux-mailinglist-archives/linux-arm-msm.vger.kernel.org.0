index 000000000000..3a754179a848
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/x1p42100-microsoft-sp12in.dts
@@ -0,0 +1,1160 @@
+// SPDX-License-Identifier: BSD-3-Clause
+/*
